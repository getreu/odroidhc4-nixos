#!/bin/sh

#set -x

###
# OPEN DISKS
###
RAIDDISK1=/dev/sda
RAIDDISK2=/dev/sdb


open_disks() {

	echo "UNLOCK AND MOUNT ENCRYPTED DISK"

	# Set spindown time
	hdparm -S 244 $RAIDDISK1
  hdparm -S 244 $RAIDDISK2

	echo "*** Assemble Raid 1"
  mdadm -A /dev/md1 ${RAIDDISK1}1 ${RAIDDISK2}1
  mdadm --detail --scan
  #   ARRAY /dev/md1 metadata=... name=bucketnas2:1 UUID=b1feed4...

	MD_DISK="$(ls /dev/md*|head -n 1)"

	echo "*** Unlock: $MD_DISK"

	# setup decryption layer (will prompt for passwd)
	cryptsetup open --type luks "$MD_DISK"  md1-crypt


	# mount filesystem
	umount /dev/mapper/md1-crypt
	mount -t ext4 -o rw,noexec,relatime /dev/mapper/md1-crypt /srv/dev-disk-by-uuid-1d65e612-b548-4f91-b089-1ad4260ed796/
	echo "*** Check mount:\n$(mount | grep /dev/mapper/md1-crypt -)"
	sleep 5

	# restart services
	#service minidlna restart
	#service smbd restart
	#service nmbd restart
	service nfs-kernel-server restart

	# display 
	echo 
	echo "*** $MD_DISK status"
	cryptsetup status md1-crypt
}





###
# Main
###

#set -x
open_disks
sleep 135m

/root/bin/stop-disks


