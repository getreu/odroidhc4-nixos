#!/bin/sh

### 
# CLOSE DISKS
###

close_disks() {
	echo
	echo "UNMOUNT AND LOCK ENCRYPTED DISK"
	# Stop services
	#service minidlna stop
	service smbd stop
	service nmbd stop
	service nfs-kernel-server stop
	
        # Unmount filesystem
	MAPPER_MD_DISK="$(ls /dev/mapper/md*|head -n 1)"
	echo Try to unmont $MAPPER_MD_DISK
	umount --detach-loop --lazy --force $MAPPER_MD_DISK \
	|| { echo "$MAPPER_MD_DISK: unmounting failed, aborting." ; exit 1; } 
	sleep 5 

	# Forget key
	cryptsetup close /dev/md1-crypt 
	cryptsetup status /dev/md1-crypt

	# Stop Raid 1
        #mdadm -S /dev/md1
        #mdadm --detail --scan
}


###
# Main
###

#set -x
close_disks 

